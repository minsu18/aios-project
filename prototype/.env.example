# AIOS Prototype — Environment Variables
# Copy to .env and fill in your keys

# Inference backend: placeholder | openai | anthropic
AIOS_INFERENCE=placeholder

# OpenAI (for AIOS_INFERENCE=openai, voice STT, image vision)
OPENAI_API_KEY=

# Anthropic (for AIOS_INFERENCE=anthropic, image vision fallback)
ANTHROPIC_API_KEY=

# Optional model overrides
# AIOS_OPENAI_MODEL=gpt-4o-mini
# AIOS_ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# AIOS_REGISTRY_URL=https://raw.githubusercontent.com/.../registry/skills.json
