{
  "name": "aios-prototype",
  "version": "0.1.0",
  "description": "AIOS Phase 1 prototype: AI core + skill runtime (host validation)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "demo": "tsc && node dist/index.js demo",
    "skills": "tsc && node dist/index.js skills",
    "simulate": "tsc && node dist/index.js simulate",
    "simulate:no-vm": "tsc && node dist/index.js simulate --no-vm"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "chalk": "^5.3.0",
    "openai": "^4.70.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["aios", "ai", "mcp", "skill"],
  "license": "MIT"
}
